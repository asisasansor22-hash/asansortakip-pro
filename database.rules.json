{
  "rules": {
    "asansor": {

      "tenants": {
        ".read": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true",

        "$tenantId": {
          "public": {
            ".read": true
          },

          ".read": "auth != null && (root.child('asansor').child('superadmins').child(auth.uid).val() === true || root.child('asansor').child('users').child(auth.uid).child('tenantId').val() === $tenantId)",

          ".write": "auth != null && (root.child('asansor').child('superadmins').child(auth.uid).val() === true || (root.child('asansor').child('users').child(auth.uid).child('tenantId').val() === $tenantId && root.child('asansor').child('tenants').child($tenantId).child('subscription').child('status').val() === 'active'))"
        }
      },

      "users": {
        ".read": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true",

        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('asansor').child('superadmins').child(auth.uid).val() === true)",

          ".write": "auth != null && (root.child('asansor').child('superadmins').child(auth.uid).val() === true || (root.child('asansor').child('users').child(auth.uid).child('role').val() === 'yonetici' && root.child('asansor').child('users').child(auth.uid).child('tenantId').val() === newData.child('tenantId').val() && newData.child('role').val() === 'bakimci'))"
        }
      },

      "superadmins": {
        ".read": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true",

        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },

      "$other": {
        ".read": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('asansor').child('superadmins').child(auth.uid).val() === true"
      }

    }
  }
}
